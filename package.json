{
  "name": "@sveltejs/eslint-config",
  "version": "9.0.0",
  "description": "Svelte ESLint config",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "lint": "eslint -c index.js",
    "lint:ci": "eslint -c index.js --format junit -o reports/junit/eslint-results.xml",
    "release": "changeset publish"
  },
  "repository": "sveltejs/eslint-config",
  "keywords": [
    "eslint",
    "config",
    "eslint-config",
    "svelte"
  ],
  "author": "Svelte",
  "license": "MIT",
  "homepage": "https://github.com/sveltejs/eslint-config#readme",
  "files": [
    "index.js",
    "package.json"
  ],
  "dependencies": {
    "globals": "^17.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.8",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin-js": "^1.8.1",
    "@svitejs/changesets-changelog-github-compact": "^1.1.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-svelte": "^3.15.0",
    "svelte": "^4.2.18",
    "typescript": "^5.5.2",
    "typescript-eslint": "^8.56.0"
  },
  "peerDependencies": {
    "@eslint/js": ">= 10",
    "@stylistic/eslint-plugin-js": ">= 1",
    "eslint": ">= 10",
    "eslint-config-prettier": ">= 9",
    "eslint-plugin-n": ">= 17",
    "eslint-plugin-svelte": ">= 3",
    "typescript": ">= 5",
    "typescript-eslint": ">= 8"
  },
  "packageManager": "pnpm@9.4.0"
}
