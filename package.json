{
  "name": "@sveltejs/eslint-config",
  "version": "9.0.0",
  "description": "Svelte ESLint config",
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "lint": "eslint -c index.js",
    "lint:ci": "eslint -c index.js --format junit -o reports/junit/eslint-results.xml",
    "release": "changeset publish"
  },
  "repository": "sveltejs/eslint-config",
  "keywords": [
    "eslint",
    "config",
    "eslint-config",
    "svelte"
  ],
  "author": "Svelte",
  "license": "MIT",
  "homepage": "https://github.com/sveltejs/eslint-config#readme",
  "files": [
    "index.js",
    "index.d.ts",
    "package.json"
  ],
  "dependencies": {
    "globals": "^17.4.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@svitejs/changesets-changelog-github-compact": "^1.2.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-svelte": "^3.16.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "peerDependencies": {
    "@eslint/js": ">= 10",
    "@stylistic/eslint-plugin": ">= 5",
    "eslint": ">= 10",
    "eslint-config-prettier": ">= 9",
    "eslint-plugin-n": ">= 17",
    "eslint-plugin-svelte": ">= 3",
    "typescript": ">= 5 < 7",
    "typescript-eslint": ">= 8"
  },
  "packageManager": "pnpm@10.33.0"
}
